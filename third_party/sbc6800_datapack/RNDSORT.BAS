100 REM RNDSORT.BAS
110 REM BUBBLE SORT THE 10 RANDOM VALURS
120 REM
130 REM GENERATE RANDOM VALUES
140 DIM A(10)
150 FOR I=1 TO 10
160 A(I)=RND 
170 NEXT I
180 REM
190 REM BUBBLE SORT
200 FOR I=1 TO 9
210 FOR J=I+1 TO 10
220 IF A(I)>A(J) GOSUB 520
230 NEXT J
240 NEXT I
250 REM
260 REM PRINT RESULT
270 FOR I=1 TO 10
280 PRINT A(I)
290 NEXT I
300 END
500 REM
510 REM SWAP SUBROUTINE
520 S=A(I)
530 A(I)=A(J)
540 A(J)=S
550 RETURN
